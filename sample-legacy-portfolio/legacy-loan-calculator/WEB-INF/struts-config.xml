<?xml version="1.0" encoding="ISO-8859-1"?>
<!DOCTYPE struts-config PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 1.3//EN"
    "http://struts.apache.org/dtds/struts-config_1_3.dtd">
<struts-config>
    <form-beans>
        <form-bean name="loanForm" type="com.acme.loan.LoanForm"/>
    </form-beans>
    <action-mappings>
        <action path="/loan"
                type="com.acme.loan.LoanAction"
                name="loanForm"
                scope="request"
                input="/loan.jsp">
            <forward name="quote" path="/quote.jsp"/>
            <forward name="confirm" path="/confirm.jsp"/>
        </action>
    </action-mappings>
</struts-config>
