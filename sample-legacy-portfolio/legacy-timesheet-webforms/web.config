<?xml version="1.0"?>
<!-- ASP.NET 2.0 timesheet app config -->
<configuration>
  <connectionStrings>
    <!-- Credentials in plaintext, no encryption of this section -->
    <add name="TimesheetDB"
         connectionString="Data Source=10.0.6.15;Initial Catalog=Timesheets;User ID=ts_app;Password=Time2006!;"
         providerName="System.Data.SqlClient"/>
  </connectionStrings>
  <system.web>
    <compilation debug="true" />
    <authentication mode="Forms">
      <forms loginUrl="Login.aspx" timeout="60" requireSSL="false"/>
    </authentication>
    <sessionState mode="InProc" timeout="60"/>
    <customErrors mode="Off"/>
  </system.web>
</configuration>
